# Copy this file to .streamlit/secrets.toml and fill in your values.
# secrets.toml is gitignored — never commit real keys.
#
# On Streamlit Community Cloud, paste these key=value pairs
# into the app's Secrets settings (no need to create the file).

OPENAI_API_KEY = "sk-..."
SUPABASE_URL   = "https://your-project.supabase.co"
SUPABASE_KEY   = "your-anon-key"
